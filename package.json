{
  "name": "doctorrx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/lib/db/seed.ts",
    "db:push:staging": "ENV=staging drizzle-kit push",
    "db:push:prod": "ENV=production drizzle-kit push",
    "db:migrate:staging": "ENV=staging drizzle-kit migrate",
